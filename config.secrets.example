# Copy this to config.secrets.yml and fill in real values
# config.secrets.yml is gitignored — this example is committed

GOOGLE_OAUTH_CLIENT_ID: "your-google-oauth-client-id"
GOOGLE_OAUTH_CLIENT_SECRET: "your-google-oauth-client-secret"
CODEFORCES_EMAIL: "your-codeforces-email"
CODEFORCES_PASSWORD: "your-codeforces-password"
YOUTRACK_API_BASE: "https://your-youtrack-instance/api"
BURPSUITE_DIR: "~/path/to/burpsuite"
CODEFORCES_HANDLE: "your-codeforces-handle"
TWITTER_HANDLE: "your-twitter-handle"
YOUTRACK_PROJECT_CODE: "your-youtrack-project-code"
CODEFORCES_GROUP_ID: "your-codeforces-group-id"
MOODLE_AUTHOR_NAME: "Your Name"
MOODLE_COURSE_IDS: |
  | Course Name 1 | 12345 |
  | Course Name 2 | 67890 |
