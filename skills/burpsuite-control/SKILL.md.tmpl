## AT-SPI Control Reference

### Python Setup

```python
import gi
gi.require_version('Atspi', '2.0')
from gi.repository import Atspi
```

Must run with env vars:
```bash
DISPLAY=:0 AT_SPI_BUS_ADDRESS="unix:path=/run/user/$(id -u)/at-spi/bus_0" python3 script.py
```

### Find Burp Application

```python
def find_burp():
    desktop = Atspi.get_desktop(0)
    for i in range(desktop.get_child_count()):
        app = desktop.get_child_at_index(i)
        if 'urp' in (app.get_name() or '').lower():
            return app
    return None

burp = find_burp()
frame = burp.get_child_at_index(0)  # main frame
```

### Dump Widget Tree

Always use `max_depth=15` â€” Burp's widget tree is not massive and shallow dumps miss nested widgets.

```python
def dump_tree(node, indent=0, max_depth=15):
    try:
        role = node.get_role_name()
        name = node.get_name() or ''
        text = ''
        try:
            ti = node.get_text()
            if ti:
                text = ti.get_text(0, min(ti.get_character_count(), 80))
        except: pass
        ai = node.get_action_iface()
        actions = ''
        if ai and ai.get_n_actions() > 0:
            actions = f' [{", ".join(ai.get_action_name(a) for a in range(ai.get_n_actions()))}]'
        extra = f' text="{text}"' if text else ''
        if name or text or actions or role not in ('panel', 'filler', 'layered pane', 'root pane'):
            print(f"{'  ' * indent}[{role}] \"{name}\"{extra}{actions}")
        if indent < max_depth:
            for i in range(min(node.get_child_count(), 30)):
                child = node.get_child_at_index(i)
                if child: dump_tree(child, indent + 1, max_depth)
    except: pass
```

### Find & Interact

```python
def find_by_name(node, name, depth=0, max_d=15):
    if depth > max_d: return None
    try:
        if name in (node.get_name() or ''):
            return node
        for i in range(node.get_child_count()):
            r = find_by_name(node.get_child_at_index(i), name, depth+1, max_d)
            if r: return r
    except: pass
    return None

def find_all_by_role(node, role_name, results=None, depth=0, max_d=15):
    if results is None: results = []
    if depth > max_d: return results
    try:
        if node.get_role_name() == role_name:
            results.append(node)
        for i in range(node.get_child_count()):
            find_all_by_role(node.get_child_at_index(i), role_name, results, depth+1, max_d)
    except: pass
    return results

# Click a button
btn = find_by_name(frame, "Next")
btn.get_action_iface().do_action(0)

# Click a radio button
radio = find_by_name(frame, "Temporary project in memory")
radio.get_action_iface().do_action(0)

# Toggle a checkbox
cb = find_by_name(frame, "Pause automated tasks")
cb.get_action_iface().do_action(0)
```

### Tab Navigation

Burp's top-level tabs have no action interface. Use the selection interface on the parent tab list:

```python
# Find the top-level "Discover" tab list
tab_lists = find_all_by_role(frame, "page tab list")
for tl in tab_lists:
    if tl.get_name() == "Discover":
        si = tl.get_selection_iface()
        # Select by index: 0=Dashboard, 1=Target, 2=Proxy, 3=Intruder,
        # 4=Repeater, 5=Collaborator, 6=Sequencer, 7=Decoder,
        # 8=Comparer, 9=Logger, 10=Organizer, 11=Extensions, 12=Discover
        si.select_child(2)  # Switch to Proxy tab
        break
```

