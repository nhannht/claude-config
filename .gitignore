# Ignore everything by default
*

# === Allow: core config (hand-edited, no secrets) ===
!.gitignore
!settings.json
!.mcp.json
!CLAUDE.md

# === Deny: .env (generated, contains secrets) ===
.env

# === Allow: template system ===
!generate.ts
!config.yml
!config.secrets.example
!package.json
!bun.lock
!*.tmpl

# === Deny: local/secret config (NEVER commit) ===
config.local.yml
config.secrets.yml

# === Allow: skills ===
!skills/
!skills/**

# === Deny: generated SKILL.md (has .tmpl source) ===
skills/youtrack/SKILL.md

# === Deny: private skills (symlinked from claude-config-private) ===
skills/codeforce-hcmus-control
skills/moodle-control
skills/burpsuite-control
skills/discord-self-botting
skills/twitter_manipulator
skills/zalo-control
skills/tabfs-hacker
skills/browser-control
skills/asus-browser-control
skills/mathematica-control

# === Allow: gstack submodule ===
!skills/gstack

# === Deny: gstack symlinks (auto-created, point into submodule) ===
skills/benchmark
skills/browse
skills/canary
skills/careful
skills/codex
