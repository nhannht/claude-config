# Ignore everything by default
*

# === Allow: core config (hand-edited, no secrets) ===
!.gitignore
!settings.json
!.mcp.json
!CLAUDE.md

# === Deny: .env (generated, contains secrets) ===
.env

# === Allow: template system ===
!generate.ts
!config.yml
!config.secrets.example
!package.json
!bun.lock
!*.tmpl

# === Deny: local/secret config (NEVER commit) ===
config.local.yml
config.secrets.yml

# === Allow: skills ===
!skills/
!skills/**

# === Deny: generated SKILL.md (has .tmpl source) ===
skills/codeforce-control/SKILL.md
skills/burpsuite-control/SKILL.md
skills/youtrack/SKILL.md

# === Deny: gstack symlinks (installed locally, not committed) ===
skills/gstack/
skills/benchmark
skills/browse
skills/canary
skills/careful
skills/codex
skills/design-consultation
skills/design-review
skills/document-release
skills/freeze
skills/gstack-upgrade
skills/guard
skills/investigate
skills/land-and-deploy
skills/office-hours
skills/plan-ceo-review
skills/plan-design-review
skills/plan-eng-review
skills/qa
skills/qa-only
skills/retro
skills/review
skills/setup-browser-cookies
skills/setup-deploy
skills/ship
skills/unfreeze
