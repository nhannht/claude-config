# Ignore everything by default
*

# === Allow: core config (hand-edited, no secrets) ===
!.gitignore
!settings.json
!.mcp.json
!CLAUDE.md
!README.md
!secrets.example.yml

# === Allow: rules ===
!rules/
!rules/**

# === Deny: secrets and env ===
.env
secrets.yml

# === Allow: skills ===
!skills/
!skills/**

# === Deny: private skills plugin (gitignored, never commit) ===
plugins/

# === Allow: gstack submodule ===
!skills/gstack

# === Deny: gstack symlinks (auto-created, point into submodule) ===
skills/benchmark
skills/browse
skills/canary
skills/careful
skills/codex
skills/design-consultation
skills/design-review
skills/document-release
skills/freeze
skills/gstack-upgrade
skills/guard
skills/investigate
skills/land-and-deploy
skills/office-hours
skills/plan-ceo-review
skills/plan-design-review
skills/plan-eng-review
skills/qa
skills/qa-only
skills/retro
skills/review
skills/setup-browser-cookies
skills/setup-deploy
skills/ship
skills/unfreeze
