"""Block commands/content that contain weak or human-crafted passwords.

Enforces that any password generation uses cryptographic randomness
(openssl rand, /dev/urandom, secrets module, etc.) instead of hardcoded strings.
"""

import json
import re
import sys

# Patterns that indicate a password is being SET (not just read/checked)
PASSWORD_ASSIGNMENT_PATTERNS = [
    # CLI flags
    r"--password[\s=]+['\"]?([^'\"$\s]+)",
    r"-p[\s]+['\"]?([^'\"$\s]+)",
    # Environment variables
    r"(?:PASSWORD|PASSWD|SECRET|TOKEN|API_KEY)[\s]*=[\s]*['\"]?([^'\"$\s}{]+)",
    # JSON fields
    r'"(?:password|passwd|secret|token|api_key|apikey)":\s*"([^"$]+)"',
    # YAML fields
    r"(?:password|passwd|secret|token|api_key|apikey):\s+['\"]?([^'\"$\s]+)",
    # curl -u user:pass
    r"curl\s+.*-u\s+\w+:([^\s'\"]+)",
    # htpasswd
    r"htpasswd\s+.*-b\s+\S+\s+\S+\s+(\S+)",
]

# Patterns that indicate secure generation (allowed)
SECURE_GENERATION_PATTERNS = [
    r"openssl\s+rand",
    r"/dev/u?random",
    r"secrets\.\w+",          # Python secrets module
    r"crypto\.random",        # Node crypto
    r"SecureRandom",          # Ruby/Java
    r"uuid\.uuid4",           # UUIDs as tokens
    r"\$\(",                  # Command substitution (likely generating)
    r"`[^`]*rand[^`]*`",     # Backtick substitution with rand
    r"pwgen\b",
    r"apg\b",
    r"head\s+.*/(u?random|urandom)",
    r"tr\s+.*/(u?random|urandom)",
]

# Minimum entropy heuristic: if the password candidate looks random enough, allow it
# (32+ chars with mixed case/digits/special = likely generated externally)
HIGH_ENTROPY_RE = re.compile(r"^[A-Za-z0-9+/=_-]{24,}$")

MSG = (
    "BLOCKED: Detected a hardcoded password/secret. "
    "Generate passwords using: openssl rand -base64 24 (or equivalent "
    "cryptographic randomness like python secrets, /dev/urandom). "
    "Use command substitution to inline it, e.g.: "
    '--password="$(openssl rand -base64 24)"'
)


def content_has_secure_generation(text: str) -> bool:
    """Check if the text contains evidence of secure password generation."""
    for pattern in SECURE_GENERATION_PATTERNS:
        if re.search(pattern, text):
            return True
    return False


def find_weak_passwords(text: str) -> list[str]:
    """Find password values that appear to be hardcoded and weak."""
    weak = []
    for pattern in PASSWORD_ASSIGNMENT_PATTERNS:
        for match in re.finditer(pattern, text, re.IGNORECASE):
            value = match.group(1) if match.lastindex else match.group(0)
            # Skip if it's a variable reference or command substitution
            if value.startswith("$") or value.startswith("`"):
                continue
            # Skip placeholder/example values
            if value.lower() in (
                "changeme", "password", "xxx", "***", "your_password_here",
                "example", "null", "none", "true", "false",
            ):
                continue
            # Skip if it looks like high-entropy (likely pre-generated)
            if HIGH_ENTROPY_RE.match(value) and len(value) >= 24:
                continue
            # Skip very short values (likely not real passwords, e.g. flags)
            if len(value) < 8:
                continue
            weak.append(value)
    return weak


data = json.load(sys.stdin)
tool = data.get("tool_name", "")
tool_input = data.get("tool_input", {})

if tool == "Bash":
    cmd = tool_input.get("command", "")
    # If the command itself generates passwords securely, allow it
    if content_has_secure_generation(cmd):
        sys.exit(0)
    weak = find_weak_passwords(cmd)
    if weak:
        print(MSG, file=sys.stderr)
        sys.exit(2)

elif tool in ("Write", "Edit"):
    content = tool_input.get("content" if tool == "Write" else "new_string", "")
    if content_has_secure_generation(content):
        sys.exit(0)
    weak = find_weak_passwords(content)
    if weak:
        print(MSG, file=sys.stderr)
        sys.exit(2)
