{
  "env": {
    "MCP_TIMEOUT": "30000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/pre-glob-locate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/pre-glob-locate.sh"
          },
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/block-secrets-read.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/block-secrets-read.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__serena__replace_symbol_body",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/post-serena-format.sh"
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_after_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/post-serena-format.sh"
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_before_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/post-serena-format.sh"
          }
        ]
      }
    ],
    "Stop": []
  },
  "statusLine": {
    "type": "command",
    "command": "printf '\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m' \"$(whoami)\" \"$(hostname -s)\" \"$(pwd)\""
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "dev-tools@jezweb-skills": true,
    "plugin-dev@claude-plugins-official": true,
    "private-skills@local": true
  },
  "extraKnownMarketplaces": {
    "jezweb-skills": {
      "source": {
        "source": "github",
        "repo": "jezweb/claude-skills"
      }
    },
    "local": {
      "source": {
        "source": "directory",
        "path": "/home/ubuntu/.claude/plugins/marketplaces/local"
      }
    }
  },
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true
}
