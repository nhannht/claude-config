{
  "env": {
    "MCP_TIMEOUT": "30000",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DEBUG_LOG_LEVEL": "verbose"
  },
  "permissions": {
    "allow": [
      "Bash(tg-notify Done: fixed content-speech sync for S2.2, S3.2, S3.3, S3.4. Created remotion-perf private skill. Memo optimizations committed earlier.:*)",
      "WebFetch(domain:www.paulgraham.com)",
      "Bash(curl -s https://www.paulgraham.com/brandage.html)",
      "Bash(tg-notify:*)",
      "Bash(chmod +x:*)"
    ],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/pre-glob-locate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/pre-glob-locate.sh"
          },
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/block-secrets-read.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/block-secrets-read.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__serena__replace_symbol_body",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/post-serena-format.sh"
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_after_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/post-serena-format.sh"
          }
        ]
      },
      {
        "matcher": "mcp__serena__insert_before_symbol",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/post-serena-format.sh"
          }
        ]
      }
    ],
    "Stop": [],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/home/ubuntu/.claude/hooks/post-compact-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf '\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m' \"$(whoami)\" \"$(hostname -s)\" \"$(pwd)\""
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "private-skills@ikarus": true
  },
  "extraKnownMarketplaces": {
    "jezweb-skills": {
      "source": {
        "source": "github",
        "repo": "jezweb/claude-skills"
      }
    },
    "ikarus": {
      "source": {
        "source": "directory",
        "path": "/home/ubuntu/.claude/plugins/marketplaces/ikarus"
      }
    }
  },
  "effortLevel": "medium",
  "autoCompactWindow": 200000,
  "autoUpdatesChannel": "stable",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "model": "sonnet"
}
