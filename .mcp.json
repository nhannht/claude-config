{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {}
    },
    "context-hub": {
      "type": "stdio",
      "command": "/home/ubuntu/.bun/bin/chub-mcp",
      "args": [],
      "env": {}
    },
    "serena": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "exec uvx --from git+https://github.com/oraios/serena serena start-mcp-server --context claude-code --project \"$HOME/.claude\""
      ],
      "env": {}
    }
  }
}
